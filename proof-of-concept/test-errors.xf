-- Error test cases
data Bool = True | False

-- Should SUCCEED - identity function
id : (b : Bool) -> Bool
id b = b

-- Should FAIL - type mismatch: body returns Bool, not Bool→Bool
broken : (b : Bool) -> Bool -> Bool
broken b = b

-- Should SUCCEED - constant function
const_true : (b : Bool) -> Bool
const_true b = True

-- Should FAIL - missing branch (only covers True)
partial : (b : Bool) -> Bool
partial b = match b
  | True -> True
